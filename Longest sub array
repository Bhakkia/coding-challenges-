class Solution:
    def longestSubarray(self, arr, k):
        max_len = 0

        for i in range(len(arr)):
            total = 0

            for j in range(i, len(arr)):
                total += arr[j]

                if total == k:
                    max_len = max(max_len, j - i + 1)

        return max_len
arr = [10, 5, 2, 7, 1, 9]
k = 15

obj = Solution()
print(obj.longestSubarray(arr, k))
