class Solution:
    def findUnion(self, a, b):
        union = []
        for x in a:
            if x not in union:
                union.append(x)
        for x in b:
            if x not in union:
                union.append(x)
        return union
a = [1,2,4,5,6]       
b = [2,3,5,7]
obj = Solution()
print(obj.findUnion(a,b))
