class Solution:
    def getSecondLargest(self, arr):
        largest = second = -1

        for num in arr:
            if num > largest:
                second = largest
                largest = num
            elif num > second and num != largest:
                second = num

        return second


arr = [12, 35, 1, 10, 34, 1]

obj = Solution()
print(obj.getSecondLargest(arr))
        
